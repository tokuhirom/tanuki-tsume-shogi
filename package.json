{
  "name": "tanuki-tsune-shogi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:wasm": "cd wasm && wasm-pack build --target web --out-dir ../src/wasm-pkg",
    "dev": "npm run build:wasm && vite",
    "build": "npm run build:wasm && npm run build:puzzles && npm run validate && vite build",
    "preview": "vite preview",
    "generate": "cargo run --release --manifest-path generator/Cargo.toml --",
    "validate": "cargo run --release --manifest-path generator/Cargo.toml -- validate",
    "mine:7": "node scripts/mine-curated.js --mate=7 --tries=12000",
    "mine:9": "node scripts/mine-curated.js --mate=9 --tries=16000",
    "add:curated": "node scripts/add-curated.js",
    "build:puzzles": "cargo run --release --manifest-path generator/Cargo.toml -- --seed=20260307",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "npx oxlint src/app.js src/shogi-core.js scripts/*.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "oxlint": "^1.51.0",
    "vite": "^7.3.1",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^4.0.18"
  }
}
